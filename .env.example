# ============================================================================
# RAG 检索增强服务 — 环境变量配置（模板）
# 复制此文件为 .env 并填入真实值
# ============================================================================

# Model 模块 — LLM 文本生成（查询改写用）
# DeepSeek API 兼容 OpenAI SDK 格式
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=your-api-key-here
MODEL_NAME=deepseek-v4-pro
MODEL_MAX_RETRIES=3
MODEL_TIMEOUT=60

# Embedding — 向量化（RAG 模块内部独立实体）
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# RAG 模块 — 向量存储与检索
RAG_RESOURCE_DIR=rag_resource
RAG_DB_DIR=rag_db
RAG_COLLECTION_NAME=faq
RAG_TOP_K=5
RAG_BM25_K1=1.5
RAG_BM25_B=0.75

# Retriever 模块 — 检索编排
RETRIEVER_MODE=hybrid
RETRIEVER_RRF_K=60

# API 模块 — HTTP 服务
API_HOST=0.0.0.0
API_PORT=8000
