# ============================================================================
# 项目环境变量配置模板
# 复制此文件为 .env 并修改真实值
# ============================================================================

# ---------------------------------------------------------------------------
# 电商平台 — shop-service
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:1234@postgres:5432/agent
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRATION_HOURS=24
INTERNAL_API_TOKEN=change-this-to-a-random-string
SHOP_SERVICE_PORT=8001
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# RAG 智能客服 — LLM 文本生成
# ---------------------------------------------------------------------------
# DeepSeek API（兼容 OpenAI SDK 格式），注册获取: https://platform.deepseek.com/
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=your-api-key-here
MODEL_NAME=deepseek-v4-pro
MODEL_MAX_RETRIES=3
MODEL_TIMEOUT=60

# ---------------------------------------------------------------------------
# RAG 智能客服 — Embedding 向量化
# ---------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# RAG 智能客服 — 向量存储与检索
# ---------------------------------------------------------------------------
RAG_RESOURCE_DIR=rag_resource
RAG_DB_DIR=rag_db
RAG_COLLECTION_NAME=faq
RAG_TOP_K=5
RAG_BM25_K1=1.5
RAG_BM25_B=0.75

# ---------------------------------------------------------------------------
# RAG 智能客服 — 检索编排 + API 服务
# ---------------------------------------------------------------------------
RETRIEVER_MODE=hybrid
RETRIEVER_RRF_K=60
API_HOST=0.0.0.0
API_PORT=8000
